<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
    MyDemoApp E2E Suite — LOCAL (no SauceLabs needed)

    Before running:
    1. Android emulator চালু করুন (AVD Manager → Play button)
    2. Appium server চালু করুন:
       npx appium
    3. Right-click testng-mydemo-local.xml → Run As → TestNG Suite
-->

<!-- cd C:\Users\rezau\eclipse-workspace\appium-tests
		mvn clean test -DsuiteXmlFile=testng-saucelabs.xml  appium        adb devices -->
		
<suite name="MyDemoAppLocalSuite" verbose="1">

    <parameter name="runMode"         value="local"/>
    <parameter name="saucelabsUser"   value=""/>
    <parameter name="saucelabsKey"    value=""/>
    <parameter name="platformVersion" value=""/>

    <listeners>
        <listener class-name="listeners.ScreenshotListener"/>
    </listeners>

    <test name="MyDemoApp — E2E Login + Cart + Checkout (Local)">
        <classes>
            <class name="tests.MyDemoE2ETests"/>
        </classes>
    </test>

</suite>
